PORT=3000
NODE_ENV=production
BASE_URL=https://your-domain.com
DATABASE_PATH=./data/datelife.db

# 条形码 API（可选）
BARCODE_API_KEY=your_barcode_api_key_here

# 认证系统（必填）
JWT_SECRET=your_64_char_random_hex_here
RESEND_API_KEY=re_your_resend_api_key_here
TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAxxxxxxxxxx

# 注册模式: true=需要邀请码, false=公开注册
INVITE_MODE=false
